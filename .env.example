# ============================================================
# CONFIGURAÇÃO DA API — Hospital Readmission Prediction
# Copie este arquivo para .env e ajuste os valores
# NUNCA commite o arquivo .env com valores reais
# ============================================================

# ---- Autenticação (JWT) ----
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-min-32-chars-hex
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Auditoria / LGPD ----
AUDIT_DB_PATH=./audit/audit.db
# Dias de retenção dos registros (CFM: mínimo 20 anos para prontuários)
AUDIT_LOG_RETENTION_DAYS=7300

# ---- Modelo ----
MODEL_DIR=./model
# Ative após rodar model/calibrate.py
USE_CALIBRATED_MODEL=false

# ---- API ----
# Origens permitidas para CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8000
# development | production
ENVIRONMENT=development
# Hosts confiáveis (separados por vírgula) — use * apenas em dev
TRUSTED_HOSTS=localhost,127.0.0.1

# ---- Rate Limiting ----
RATE_LIMIT_PREDICT=30/minute
RATE_LIMIT_BATCH=5/minute
RATE_LIMIT_EXPLAIN=20/minute

# ---- Monitoramento ----
# PSI > PSI_ALERT_THRESHOLD dispara alerta de deriva de dados
PSI_ALERT_THRESHOLD=0.2
# Subgrupos com AUC abaixo deste valor geram alerta de fairness
MIN_SUBGROUP_AUC=0.60
